{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "threebody:search": "bun scripts/threebody-search.mjs",
    "threebody:overnight": "bun scripts/threebody-search.mjs --checkpoint .codex/threebody-search/overnight-v5.jsonl --catalog .codex/threebody-search/overnight-v5-catalog.json --catalogModule .codex/threebody-search/overnight-v5-catalog.ts --frames 100000 --seconds 28800 --candidates 0 --top 80 --workers auto --progressEvery 100",
    "threebody:promote": "bun scripts/threebody-search.mjs --checkpoint .codex/threebody-search/overnight-v5.jsonl --catalog app/games/threebody-catalog.json --catalogModule app/games/threebody-catalog.ts --frames 100000 --candidates 0 --top 80",
    "threebody:verify": "bun scripts/threebody-search.mjs --verify-catalog",
    "start": "next start",
    "lint": "oxlint .",
    "doctor": "react-doctor --no-score --blocking warning",
    "check": "npm run lint && npm run doctor && npm exec -- tsc --noEmit"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "engines": {
    "node": "24.x",
    "npm": ">=11.0.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "type": "module",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "oxlint": "^1.70.0",
    "oxlint-plugin-react-doctor": "^0.5.6",
    "react-doctor": "^0.5.6",
    "typescript": "^6.0.3"
  }
}
