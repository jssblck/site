{
  "name": "site",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "threebody:search": "bun scripts/threebody-search.mjs",
    "threebody:overnight": "bun scripts/threebody-search.mjs --checkpoint .codex/threebody-search/overnight-v5.jsonl --catalog .codex/threebody-search/overnight-v5-catalog.json --catalogModule .codex/threebody-search/overnight-v5-catalog.ts --frames 100000 --seconds 28800 --candidates 0 --top 80 --workers auto --progressEvery 100",
